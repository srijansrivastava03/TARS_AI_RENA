# AgriScan Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=5001
DEBUG=True

# Gemini API Key (for multilingual RAG diagnosis)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (fallback for RAG diagnosis)
OPENAI_API_KEY=your_openai_api_key_here

# Enable online RAG (set to True to use LLM APIs)
USE_ONLINE_RAG=True

# CORS Origins (comma-separated, * for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
